{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  // index.html is the Vite entry (loads src/index.jsx); test files and the
  // Vitest setup are reached only by the test runner, and the build tooling
  // config files are loaded by Vite/ESLint, so all are declared explicitly.
  "entry": [
    "index.html",
    "src/index.jsx",
    "src/setupTests.js",
    "src/**/*.test.{js,jsx}",
    "vite.config.js",
    "eslint.config.mjs"
  ]
}
